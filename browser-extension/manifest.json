{
  "manifest_version": 3,
  "name": "Sparkit Mimic",
  "version": "1.0",
  "description": "Mimic images using Sparkit AI",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.pinterest.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.pinterest.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}

